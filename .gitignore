build/
DerivedData/
*.xcarchive/
*.xcarchive
*.dSYM/
*.dSYM

# IPA / sideload packaging
*.ipa
Payload/
ExportOptions.plist

# Swift Package Manager (resolved on demand)
.build/
.swiftpm/

